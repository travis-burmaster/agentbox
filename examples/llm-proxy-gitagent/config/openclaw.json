{
  "gateway": {
    "mode": "local",
    "port": 3000,
    "bind": "lan",
    "auth": {
      "mode": "token"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {"id": "claude-sonnet-4-6", "name": "claude-sonnet-4-6"},
          {"id": "claude-haiku-4-5-20251001", "name": "claude-haiku-4-5-20251001"},
          {"id": "claude-opus-4-6", "name": "claude-opus-4-6"}
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/claude-sonnet-4-6"
      },
      "workspace": "/agentbox/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "commands": {
    "restart": true
  }
}
