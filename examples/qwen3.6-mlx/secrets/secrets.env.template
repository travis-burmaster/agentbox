# Optional: token gating for the openclaw gateway.
# Leave empty for local-only loopback use; set to a strong random string if you
# expose the gateway over LAN.
OPENCLAW_GATEWAY_TOKEN=

# Optional: web-search provider API keys. DuckDuckGo (default in
# config/openclaw.json) needs no key — only fill these in if you swap providers.
BRAVE_API_KEY=
TAVILY_API_KEY=
EXA_API_KEY=
PERPLEXITY_API_KEY=
SEARXNG_BASE_URL=
