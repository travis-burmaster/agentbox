# AgentBox + Ollama + Web Search — secrets template
#
# Copy this file to secrets.env and fill in any values you need.
# For the default DuckDuckGo provider you don't need ANY of these — leave them blank.

# Optional: gateway auth token. If unset, the gateway runs unauthenticated on localhost.
OPENCLAW_GATEWAY_TOKEN=

# --- Web search providers (only if you change tools.web.search.provider) ---
# Brave Search:        https://brave.com/search/api/
BRAVE_API_KEY=
# Tavily:              https://tavily.com/
TAVILY_API_KEY=
# Exa:                 https://exa.ai/
EXA_API_KEY=
# Perplexity:          https://docs.perplexity.ai/
PERPLEXITY_API_KEY=
# SearXNG:             self-hosted, e.g. http://host.docker.internal:8080
SEARXNG_BASE_URL=
