{
  "gateway": {
    "mode": "local",
    "port": 3000,
    "bind": "loopback",
    "auth": {
      "mode": "token"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/claude-sonnet-4-6"
      },
      "workspace": "/agentbox/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "baseUrl": "http://127.0.0.1:11434",
        "apiKey": "not-needed",
        "api": "ollama",
        "models": [
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet (LLM Proxy)",
            "contextWindow": 200000,
            "maxTokens": 16384
          },
          {
            "id": "claude-haiku-4-5-20251001",
            "name": "Claude Haiku (LLM Proxy)",
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus (LLM Proxy)",
            "contextWindow": 200000,
            "maxTokens": 16384
          }
        ]
      }
    }
  },
  "commands": {
    "restart": true
  }
}
