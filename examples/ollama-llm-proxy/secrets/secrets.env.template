# Copy this file to secrets.env and fill in your values.
# secrets.env is gitignored — never commit real credentials.

# Claude OAuth token (required)
# Get from: cat ~/.openclaw/agents/main/agent/auth-profiles.json | python3 -c "
#   import sys,json; d=json.load(sys.stdin)
#   print(d['profiles']['anthropic:default']['token'])
# "
CLAUDE_OAUTH_TOKEN=your-claude-oauth-token-here

# Optional: second token for failover
# CLAUDE_OAUTH_TOKEN_1=your-second-token

# Optional: Telegram bot token for messaging integration
# TELEGRAM_BOT_TOKEN=your-bot-token-here
